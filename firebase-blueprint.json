{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A service offered by MOSTBOOKED",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "icon": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "price"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A booking inquiry from a user",
      "type": "object",
      "properties": {
        "serviceTitle": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "userWhatsApp": { "type": "string" },
        "userMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["serviceTitle", "userEmail", "category"]
    },
    "Mail": {
      "title": "Mail",
      "description": "A contact message from the contact page",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "whatsapp": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "responded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "subject", "message"]
    }
  },
  "firestore": {
    "/sites/mostbooked/services": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "/sites/mostbooked/inquiries_contactus": {
      "schema": "Inquiry",
      "description": "Collection of user inquiries"
    },
    "/public/{userId}/inquiries_contactus": {
      "schema": "Inquiry",
      "description": "User specific inquiries"
    },
    "/sites/mostbooked/mail": {
      "schema": "Mail",
      "description": "Collection of contact messages"
    },
    "/sites/mostbooked/bookings/contact": {
      "schema": "object",
      "description": "Official contact information"
    }
  }
}
